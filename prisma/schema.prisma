datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String?         // null for Github OAuth users
  githubId       String?         @unique
  role           String          @default("STUDENT") // "ADMIN" or "STUDENT"
  status         String          @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  studentProfile Student?
}

model Student {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  username  String   @unique // public route slug /profile/[username]
  name      String
  role      String   // e.g. "Frontend Lead", "Machine Learning Enthusiast"
  bio       String   @db.Text
  avatarUrl String   // URL in Cloudflare R2
  github    String?
  linkedin  String?
  customCss String?  @db.Text
  stats     Json     @default("{}") // e.g. {"coffeeConsumed": 24, "bugsFixed": 404}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Memory {
  id           String   @id @default(uuid())
  imageUrl     String   // R2 image path
  description  String   @db.Text
  date         DateTime
  uploadedBy   String   // user ID of uploader
  uploaderName String   // display name of uploader
  location     String?
  createdAt    DateTime @default(now())
}

model Bug {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  status      String   @default("OPEN") // "OPEN", "IN_PROGRESS", "RESOLVED"
  reporter    String   // display name or username
  createdAt   DateTime @default(now())
}
