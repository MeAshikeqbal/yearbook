datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String?         // null for Github OAuth users
  githubId       String?         @unique
  role           String          @default("STUDENT") // "ADMIN" or "STUDENT"
  status         String          @default("PENDING") // "PENDING", "APPROVED", "REJECTED"
  idCardUrl      String?         // R2 storage URL for ID photo verification
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  studentProfile Student?
}

model Student {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique
  username  String   @unique // public route slug /profile/[username]
  name      String
  role      String   // e.g. "Frontend Lead", "Machine Learning Enthusiast"
  bio       String   @db.Text
  avatarUrl String   // URL in Cloudflare R2
  github    String?
  linkedin  String?
  customCss String?  @db.Text
  stats     Json     @default("{}") // e.g. {"coffeeConsumed": 24, "bugsFixed": 404}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Memory {
  id           String   @id @default(uuid())
  imageUrl     String   // R2 image path
  description  String   @db.Text
  date         DateTime
  uploadedBy   String   // user ID of uploader
  uploaderName String   // display name of uploader
  location     String?
  createdAt    DateTime @default(now())
}

model Bug {
  id           String   @id @default(uuid())
  title        String
  description  String   @db.Text
  status       String   @default("OPEN") // "OPEN", "IN_PROGRESS", "RESOLVED"
  reporter     String   // display name or username
  githubNumber Int?     @unique
  githubUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model EmailVerification {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ModerationLog {
  id          String   @id @default(uuid())
  adminId     String
  adminName   String
  targetId    String
  targetName  String
  action      String   // "APPROVE", "REJECT", "SUSPEND", "UNSUSPEND", "DELETE"
  reason      String?  @db.Text
  createdAt   DateTime @default(now())
}

model RateLimit {
  id        String   @id @default(uuid())
  key       String   @unique // e.g. "rate:auth:email:user@example.com"
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?  @db.Text
  value       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


