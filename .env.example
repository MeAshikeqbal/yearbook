# ──────────────────────────────────────────────────────────────
#  CSE Yearbook — Environment Variables Reference
# ──────────────────────────────────────────────────────────────
#
# LOCAL DEVELOPMENT  → copy to .env.local  (used by `next dev`)
#                      AND copy to .dev.vars (used by `npm run preview`)
#
# PRODUCTION (Cloudflare Workers) → set via:
#   npx wrangler secret put <KEY_NAME>
#   (or Cloudflare Dashboard → Workers → Settings → Variables & Secrets)
#
# DATABASE NOTE: In production, use Cloudflare Hyperdrive instead of
# DATABASE_URL. Set HYPERDRIVE binding ID in wrangler.jsonc.
# Create it with:
#   npx wrangler hyperdrive create yearbook-db --connection-string="<your-pg-url>"
# ──────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Local dev only — replaced by HYPERDRIVE binding in production
DATABASE_URL="postgresql://username:password@localhost:5432/yearbook?schema=public"

# ── Cloudflare R2 (S3-compatible object storage) ─────────────
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="yearbook-media"
R2_PUBLIC_URL="https://your-r2-public-domain.com"

# ── NextAuth ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET="run-openssl-rand-hex-32-to-generate-one"
# Local: http://localhost:3000  |  Production: https://your-worker.workers.dev
NEXTAUTH_URL="http://localhost:3000"

# ── GitHub OAuth ──────────────────────────────────────────────
AUTH_GITHUB_ID="your-github-oauth-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-client-secret"

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY="re_your-resend-api-key"
SMTP_FROM="yearbook@yourdomain.com"
